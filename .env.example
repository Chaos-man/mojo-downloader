# Mojo Sells login URL and credentials
MOJO_URL=https://lb11.mojosells.com/login/
MOJO_USERNAME=your_mojo_email@example.com
MOJO_PASSWORD=your_mojo_password

# The ID of the Google Drive folder to upload into.
# Open the folder in Drive; the ID is the last segment of the URL:
#   https://drive.google.com/drive/folders/<FOLDER_ID_HERE>
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# --- Optional: Tables to download ---
# Comma-separated list of table names to download (default: FSBO,Expired).
# Names are matched case-insensitively against what appears in the Mojo UI at runtime.
# Leading/trailing spaces around each name are ignored.
#
# Simple (no quoting needed):
#   MOJO_TABLES=FSBO,Expired
#
# Names containing spaces, slashes, or dashes — wrap the whole value in double quotes:
#   MOJO_TABLES="FSBO,Agent/Corporate Owned,Notice of Sale,Pre-Foreclosure"
#
# Single table:
#   MOJO_TABLES=FRBO
#
# Leave blank (or omit entirely) to use the default: FSBO,Expired
MOJO_TABLES=

# --- Optional: Email notification on failure ---
# If set, an email is sent when all retry attempts are exhausted.
# Leave blank (or remove) to disable email alerts.
# For Gmail, use an App Password (not your account password):
#   https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFY_EMAIL=you@gmail.com
