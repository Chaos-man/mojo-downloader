# Mojo Sells credentials
MOJO_USERNAME=your_mojo_email@example.com
MOJO_PASSWORD=your_mojo_password

# The ID of the Google Drive folder to upload into.
# Open the folder in Drive; the ID is the last segment of the URL:
#   https://drive.google.com/drive/folders/<FOLDER_ID_HERE>
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here
